{
  "name": "JPF Environment - PCD Lab",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "remoteUser": "vscode",
  // Puntiamo alla cartella superiore per vedere tutto il progetto
  "workspaceMount": "source=${localWorkspaceFolder},target=/jpf,type=bind",
  // Apriamo VS Code direttamente sulla cartella dei test per comodità
  "workspaceFolder": "/jpf"
}